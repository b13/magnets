{
	"name": "b13/magnets",
	"type": "typo3-cms-extension",
	"description": "Magnets: TYPO3 Service Package revolving around having a good API to fetch the current Geo IP and its location of the user.",
	"license": "GPL-2.0-or-later",
	"require": {
		"typo3/cms-core": "^12 || ^13 || ^14",
		"geoip2/geoip2": "^3"
	},
	"extra": {
		"typo3/cms": {
			"extension-key": "magnets"
		}
	},
	"autoload": {
		"psr-4": {
			"B13\\Magnets\\": "Classes/"
		}
	},
	"config": {
		"allow-plugins": {
			"typo3/cms-composer-installers": true,
			"typo3/class-alias-loader": true
		}
	},
	"require-dev": {
		"typo3/coding-standards": "^0.8.0",
		"saschaegerer/phpstan-typo3": "^3.0",
		"phpstan/phpstan": "^2.1"
	}
}
